---
import Layout from '../layouts/Layout.astro';

const communes = [
  "Anderlecht", "Bruxelles-Ville", "Ixelles", "Etterbeek", 
  "Evere", "Ganshoren", "Jette", "Koekelberg", 
  "Auderghem", "Schaerbeek", "Berchem-Sainte-Agathe", "Saint-Gilles", 
  "Molenbeek-Saint-Jean", "Saint-Josse-ten-Noode", "Woluwe-Saint-Lambert", 
  "Woluwe-Saint-Pierre", "Uccle", "Forest", "Watermael-Boitsfort"
];
---

<Layout title="Zones d'intervention | Kitu Plomberie" description="Nos plombiers interviennent dans toutes les communes de Bruxelles. Intervention rapide garantie.">
  <section class="page-header py-20 pt-32 text-center">
    <div class="container">
      <h1 class="text-5xl mb-4">Zones <span class="text-secondary">d'intervention</span></h1>
      <p class="text-xl text-muted max-w-2xl mx-auto">
        Présent partout à Bruxelles, Kitu Plomberie vous garantit une intervention rapide dans les 19 communes de la région bruxelloise.
      </p>
    </div>
  </section>

  <section class="map-section py-10">
    <div class="container grid grid-cols-2 gap-12 items-center">
      <div class="animate-fade-in delay-100">
        <h2 class="text-3xl mb-6">Proximité et Réactivité</h2>
        <p class="text-muted mb-6">
          Grâce à notre réseau d'artisans plombiers répartis stratégiquement dans la capitale, nous sommes capables d'intervenir chez vous en moins de 30 minutes pour toutes les urgences.
        </p>
        <div class="glass p-6 rounded-xl border-l-4 border-l-primary mb-8">
          <h3 class="text-xl mb-2 text-primary">Intervention d'Urgence</h3>
          <p class="text-sm">Disponible 24h/24 et 7j/7 pour les fuites majeures et les débouchages urgents sur toute la région bruxelloise.</p>
        </div>
        <a href="tel:+32466179127" class="btn btn-primary">Appeler un technicien</a>
      </div>
      
      <div class="communes-grid animate-fade-in delay-200">
        <div class="card p-8">
          <h3 class="text-xl mb-6 border-b border-white/10 pb-4">Les 19 Communes de Bruxelles</h3>
          <ul class="grid grid-cols-2 gap-3">
            {communes.map(commune => (
              <li class="flex items-center gap-2 text-muted hover:text-white transition cursor-default">
                <span class="text-accent text-xs">●</span> {commune}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .text-5xl { font-size: 3rem; }
  .text-3xl { font-size: 2rem; }
  .text-xl { font-size: 1.25rem; }
  .text-sm { font-size: 0.875rem; }
  .text-xs { font-size: 0.75rem; }

  @media (max-width: 768px) {
    .grid-cols-2 { grid-template-columns: 1fr; }
    .text-5xl { font-size: 2.5rem; }
  }
</style>
