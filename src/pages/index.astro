---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Accueil">
  <section class="hero py-20 flex items-center">
    <div class="container grid grid-cols-2 gap-8 items-center pt-20">
      <div class="animate-fade-in">
        <h1 class="text-5xl mb-6 leading-tight">
          Votre Expert <span class="text-primary">Plombier</span> à Bruxelles
        </h1>
        <p class="text-muted text-lg mb-8">
          Intervention rapide 24/7 pour tous vos problèmes de plomberie et débouchage. Un service professionnel, transparent et garanti.
        </p>
        <div class="flex gap-4">
          <a href="tel:+32400000000" class="btn btn-primary">Appeler le 04 00 00 00 00</a>
          <a href="/contact" class="btn btn-outline">Devis Gratuit</a>
        </div>
      </div>
      <div class="hero-image animate-fade-in delay-200">
        <div class="glass p-8 rounded-2xl relative">
          <div class="absolute -top-4 -right-4 bg-accent text-white px-4 py-2 rounded-full font-bold shadow-lg">
            Intervention en 30min!
          </div>
          <img src="https://images.unsplash.com/photo-1585704032915-c3400ca199e7?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80" alt="Plombier en intervention" class="rounded-xl w-full object-cover aspect-video" />
        </div>
      </div>
    </div>
  </section>

  <section class="services py-20 bg-surface">
    <div class="container">
      <div class="text-center mb-12 animate-fade-in">
        <h2 class="text-3xl">Nos <span class="text-secondary">Services</span></h2>
        <p class="text-muted">Des solutions adaptées à tous vos besoins en plomberie</p>
      </div>

      <div class="grid grid-cols-3 gap-8">
        <div class="card animate-fade-in delay-100">
          <div class="text-4xl mb-4">🚰</div>
          <h3>Dépannage Urgent</h3>
          <p class="text-muted mb-4">Fuite d'eau, rupture de canalisation, problème de pression. Nous intervenons rapidement.</p>
          <a href="/services" class="text-primary hover:text-white transition">En savoir plus &rarr;</a>
        </div>
        
        <div class="card animate-fade-in delay-200">
          <div class="text-4xl mb-4">🚽</div>
          <h3>Débouchage</h3>
          <p class="text-muted mb-4">WC bouchés, éviers, canalisations principales. Équipement haute pression professionnel.</p>
          <a href="/services" class="text-primary hover:text-white transition">En savoir plus &rarr;</a>
        </div>

        <div class="card animate-fade-in delay-300">
          <div class="text-4xl mb-4">🔧</div>
          <h3>Installation</h3>
          <p class="text-muted mb-4">Rénovation de salle de bain, installation de chauffe-eau, nouvelle tuyauterie.</p>
          <a href="/services" class="text-primary hover:text-white transition">En savoir plus &rarr;</a>
        </div>
      </div>
    </div>
  </section>

  <section class="cta py-20">
    <div class="container text-center">
      <div class="bg-gradient p-12 rounded-3xl relative overflow-hidden">
        <div class="relative z-10">
          <h2 class="text-4xl mb-4 text-white">Besoin d'un plombier maintenant ?</h2>
          <p class="text-lg text-white/90 mb-8 max-w-2xl mx-auto">
            Notre équipe est prête à intervenir partout à Bruxelles et ses alentours. Devis clair et sans surprise avant toute intervention.
          </p>
          <a href="tel:+32400000000" class="btn btn-accent text-lg px-8 py-4">
            ☎️ 04 00 00 00 00
          </a>
        </div>
        <!-- Decorative blobs -->
        <div class="absolute top-0 right-0 w-64 h-64 bg-white/10 rounded-full blur-3xl -translate-y-1/2 translate-x-1/3"></div>
        <div class="absolute bottom-0 left-0 w-64 h-64 bg-white/10 rounded-full blur-3xl translate-y-1/3 -translate-x-1/3"></div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .hero {
    min-height: 100vh;
    background: radial-gradient(circle at top right, rgba(59, 130, 246, 0.15) 0%, transparent 50%),
                radial-gradient(circle at bottom left, rgba(14, 165, 233, 0.1) 0%, transparent 50%);
  }

  .text-5xl {
    font-size: 3.5rem;
  }
  
  .text-4xl {
    font-size: 2.5rem;
  }
  
  .text-3xl {
    font-size: 2rem;
  }
  
  .text-lg {
    font-size: 1.125rem;
  }

  .leading-tight {
    line-height: 1.1;
  }

  @media (max-width: 768px) {
    .text-5xl {
      font-size: 2.5rem;
    }
  }
</style>
