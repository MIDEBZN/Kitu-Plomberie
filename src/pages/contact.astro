---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact | Kitu Plomberie" description="Contactez Kitu Plomberie pour un devis gratuit ou une intervention d'urgence à Bruxelles. Formulaire de contact et coordonnées.">
  <section class="page-header py-20 pt-32 text-center">
    <div class="container">
      <h1 class="text-5xl mb-4">Nous <span class="text-accent">Contacter</span></h1>
      <p class="text-xl text-muted max-w-2xl mx-auto">
        Disponible 24/7 pour les urgences. Demandez votre devis gratuit ou planifiez une intervention.
      </p>
    </div>
  </section>

  <section class="contact-section py-10 pb-20">
    <div class="container grid grid-cols-2 gap-12">
      <div class="contact-info animate-fade-in delay-100">
        <h2 class="text-3xl mb-8">Informations Pratiques</h2>
        
        <div class="space-y-6">
          <div class="card flex items-start gap-4 !p-6">
            <div class="text-3xl text-primary">📞</div>
            <div>
              <h3 class="text-xl mb-1">Téléphone (Urgence & Infos)</h3>
              <a href="tel:+32466179127" class="text-lg text-muted hover:text-primary transition">0466 17 91 27</a>
            </div>
          </div>
          
          <div class="card flex items-start gap-4 !p-6">
            <div class="text-3xl text-secondary">✉️</div>
            <div>
              <h3 class="text-xl mb-1">Email</h3>
              <a href="mailto:contact@kitu.site" class="text-lg text-muted hover:text-secondary transition">contact@kitu.site</a>
            </div>
          </div>
          
          <div class="card flex items-start gap-4 !p-6">
            <div class="text-3xl text-accent">📍</div>
            <div>
              <h3 class="text-xl mb-1">Adresse</h3>
              <p class="text-lg text-muted">Place de la Paix 23a, 1140 Evere<br/>(Intervention dans les 19 communes)</p>
            </div>
          </div>
        </div>
      </div>
      
      <div class="contact-form-container animate-fade-in delay-200">
        <form class="glass p-8 rounded-2xl flex flex-col gap-6" onsubmit="event.preventDefault(); alert('Message envoyé ! Nous vous recontacterons rapidement.');">
          <h2 class="text-2xl mb-2">Envoyez-nous un message</h2>
          
          <div class="form-group">
            <label for="name" class="block text-sm font-medium mb-2 text-muted">Nom Complet</label>
            <input type="text" id="name" required class="form-input" placeholder="Votre nom" />
          </div>
          
          <div class="form-group">
            <label for="phone" class="block text-sm font-medium mb-2 text-muted">Numéro de Téléphone</label>
            <input type="tel" id="phone" required class="form-input" placeholder="Votre téléphone" />
          </div>
          
          <div class="form-group">
            <label for="message" class="block text-sm font-medium mb-2 text-muted">Description du problème</label>
            <textarea id="message" rows="4" required class="form-input resize-none" placeholder="Décrivez votre besoin..."></textarea>
          </div>
          
          <button type="submit" class="btn btn-primary w-full mt-2">
            Envoyer la demande
          </button>
        </form>
      </div>
    </div>
  </section>
</Layout>

<style>
  .text-5xl { font-size: 3rem; }
  .text-3xl { font-size: 2rem; }
  .text-2xl { font-size: 1.5rem; }
  .text-xl { font-size: 1.25rem; }
  .text-lg { font-size: 1.125rem; }
  .text-sm { font-size: 0.875rem; }
  
  .form-input {
    width: 100%;
    padding: 1rem;
    border-radius: 0.75rem;
    background: rgba(15, 23, 42, 0.5);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: white;
    font-family: inherit;
    font-size: 1rem;
    transition: var(--transition);
  }
  
  .form-input:focus {
    outline: none;
    border-color: var(--primary);
    background: rgba(15, 23, 42, 0.8);
    box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.2);
  }
  
  .form-input::placeholder {
    color: rgba(255, 255, 255, 0.3);
  }

  @media (max-width: 768px) {
    .grid-cols-2 { grid-template-columns: 1fr; }
    .text-5xl { font-size: 2.5rem; }
  }
</style>
